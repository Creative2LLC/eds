{
  "carousel": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "name": "Carousel",
    "type": "object",
    "properties": {
      "autoplay": {
        "type": "boolean",
        "title": "Autoplay",
        "default": false
      },
      "items": {
        "type": "array",
        "title": "Slides",
        "items": {
          "type": "object",
          "properties": {
            "image": {
              "type": "string",
              "title": "Image"
            },
            "title": {
              "type": "string",
              "title": "Slide Title"
            },
            "description": {
              "type": "string",
              "title": "Slide Description"
            },
            "link": {
              "type": "string",
              "title": "Link URL"
            }
          }
        },
        "minItems": 1,
        "default": [
          {
            "image": "/assets/sample-slide1.jpg",
            "title": "Sample Slide 1",
            "description": "Default content."
          },
          {
            "image": "/assets/sample-slide2.jpg",
            "title": "Sample Slide 2",
            "description": "Add your own."
          }
        ]
      }
    }
  }
}